# Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# Nano Banana (Gemini 2.5 Flash Image) via Google AI Studio
GEMINI_API_KEY=AIza...
NANO_BANANA_MODEL=gemini-2.5-flash-image

# Buffer (classic access token — create at https://publish.buffer.com/developers/apps)
BUFFER_ACCESS_TOKEN=1/...
# Comma-separated Buffer profile IDs to post to
BUFFER_PROFILE_IDS=

# Telegram
TELEGRAM_BOT_TOKEN=
# Optional: only accept commands from these Telegram user IDs (comma-separated).
# Leave empty to allow anyone — DO NOT do that in production.
TELEGRAM_ALLOWED_USER_IDS=

# App
DATABASE_URL=sqlite:///./social_ai.db
IMAGE_DIR=./data/images
LOG_LEVEL=INFO
